{
  "title": "PoshivOn — System & AI Monitoring",
  "uid": "poshivon-main",
  "tags": ["poshivon", "production"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "HTTP — Request Rate (req/s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(poshivon_http_requests_total[1m])) by (method, path)",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP — Error Rate (%)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(poshivon_http_requests_total{status=~\"5..\"}[1m])) / sum(rate(poshivon_http_requests_total[1m]))",
          "legendFormat": "5xx Error Rate %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "HTTP — P50 / P95 / P99 Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(poshivon_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(poshivon_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(poshivon_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 10,
      "title": "AI — Requests/s",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(poshivon_ai_requests_total[5m]))",
          "legendFormat": "AI req/s"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "AI — Error Rate (%)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 4, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "100 * sum(rate(poshivon_ai_requests_total{status=\"error\"}[5m])) / sum(rate(poshivon_ai_requests_total[5m]))",
          "legendFormat": "AI Error %"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 25, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "AI — Avg Request Duration",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 8, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(poshivon_ai_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 30, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "AI — Total Tokens Used (today)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "increase(poshivon_ai_tokens_total[24h])",
          "legendFormat": "{{type}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "title": "AI — Token Consumption Rate (tokens/min)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(poshivon_ai_tokens_total{type=\"prompt\"}[5m])) * 60",
          "legendFormat": "Prompt tokens/min"
        },
        {
          "expr": "sum(rate(poshivon_ai_tokens_total{type=\"completion\"}[5m])) * 60",
          "legendFormat": "Completion tokens/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 21,
      "title": "AI — Request Duration Distribution",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(poshivon_ai_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(poshivon_ai_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(poshivon_ai_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 30,
      "title": "System — CPU Usage (%)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 31,
      "title": "System — Memory Usage (%)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "Memory %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 75, "color": "yellow" },
              { "value": 90, "color": "red" }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 32,
      "title": "System — Go Process Memory (RSS)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"poshivon_app\"}",
          "legendFormat": "RSS"
        },
        {
          "expr": "go_memstats_heap_inuse_bytes{job=\"poshivon_app\"}",
          "legendFormat": "Heap In-Use"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 40,
      "title": "HTTP — Requests by Status Code",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(poshivon_http_requests_total[1m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 41,
      "title": "Go Runtime — Goroutines",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "go_goroutines{job=\"poshivon_app\"}",
          "legendFormat": "Goroutines"
        },
        {
          "expr": "go_threads{job=\"poshivon_app\"}",
          "legendFormat": "OS Threads"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      }
    }
  ]
}
